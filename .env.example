# Copy to `.env.local` — never commit real secrets.

# -----------------------------------------------------------------------------
# Vercel production: set the same keys in Project → Settings → Environment
# Variables (Production + Preview as needed), then redeploy.
#
# Required for MVP:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   NEXT_PUBLIC_SITE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   SPOTIFY_CLIENT_ID
#   SPOTIFY_CLIENT_SECRET
#   SPOTIFY_REDIRECT_URI
#
# Spotify redirect must match the dashboard exactly, e.g.:
#   https://becks-music-dashboard.vercel.app/api/spotify/callback
# Also set NEXT_PUBLIC_SITE_URL to the same origin:
#   https://becks-music-dashboard.vercel.app
# -----------------------------------------------------------------------------

# Site URL for absolute metadata URLs (recommended in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service role (required for Phase 1 playlist read/refresh)
# — user JWT cannot read OAuth tokens from spotify_connections; server routes use this key only.
# Never use NEXT_PUBLIC_* or import this into client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Spotify OAuth — server-only; do NOT use NEXT_PUBLIC_*
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

# MUST match Spotify Dashboard redirect URI verbatim (adjust port/domain as needed).
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Gemini semantic enrichment (Phase 6) — server-only; never expose to client bundles.
# GEMINI_API_KEY=
# Optional model override (default is gemini-3.1-flash-lite in lib/config/env.ts).
# GEMINI_MODEL=
